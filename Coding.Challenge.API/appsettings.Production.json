{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    // In production the DB location should be provided via environment variable or secret store
    "Sqlite": "Data Source=/var/lib/analytics/analytics.db"
  },

  "Database": {
    "Provider": "Sqlite",
    "UseInMemory": false
  },

  "Startup": {
    // In production we typically run migrations via CI/CD pipeline, but enable here for convenience
    "EnableMigrationsOnStartup": true
  }
}
