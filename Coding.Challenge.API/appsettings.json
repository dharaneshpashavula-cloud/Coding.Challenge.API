{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Default connection string used when no environment-specific override is provided.
  "ConnectionStrings": {
    "Sqlite": "Data Source=analytics.db"
  },

  // Generic database settings. Can be overridden per-environment.
  "Database": {
    "Provider": "Sqlite",
    "UseInMemory": false
  },

  // Flags to control startup behaviour. Per-environment config can override these.
  "Startup": {
    "EnableMigrationsOnStartup": false
  }
}
