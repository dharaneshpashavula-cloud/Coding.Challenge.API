{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning"
    }
  },

  "ConnectionStrings": {
    // Tests will typically use in-memory provider; this file can be used to override if needed
    "Sqlite": "Data Source=:memory:"
  },

  "Database": {
    "Provider": "InMemory",
    "UseInMemory": true
  },

  "Startup": {
    "EnableMigrationsOnStartup": false
  }
}
